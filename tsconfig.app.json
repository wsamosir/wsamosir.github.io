{
  "compilerOptions": {
    "moduleResolution": "node",
    "types": ["svelte"],
    "allowJs": true,
    "module": "esnext",
    "target": "esnext",
    "lib": ["DOM", "ESNext"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}